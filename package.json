{
	"name": "obsidian-pretty-urls",
	"version": "1.2.0",
	"description": "A plugin for Obsidian to improve display of URLs in reading view",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.39.4",
		"@types/node": "^24.0.0",
		"esbuild": "0.28.0",
		"eslint-plugin-obsidianmd": "0.3.0",
		"globals": "17.6.0",
		"jiti": "2.7.0",
		"jsdom": "^29.1.1",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "8.59.3",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
